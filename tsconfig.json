{
    "extends": "@tsconfig/node24",
    "compilerOptions": {
        "strict": false,
        "verbatimModuleSyntax": false,
        "allowJs": true,
        "noEmit": true,
        "ignoreDeprecations": "6.0",
        "baseUrl": ".",
        "rootDir": ".",
        "types": ["node", "jest"],
        "paths": {
            "~src/*": ["src/*"],
            "~test/*": ["test/*"],
            "~resources/*": ["resources/*"]
        },
        "forceConsistentCasingInFileNames": true,
        "isolatedModules": true
    },
    "include": ["./src/**/*", "./test/**/*", "./test-generated/**/*", "./resources/**/*", "./*.ts"]
}
